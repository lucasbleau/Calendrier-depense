generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Expense {
  id         String   @id @default(cuid())
  date       String
  label      String
  amount     Float
  type       String
  category   String
  created_at DateTime @default(now())

  @@map("expenses")
}
